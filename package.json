{
  "name": "3d-earth-toolkit",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "vite build && gh-pages -d dist",
    "build:chrome": "node scripts/generate-icons.mjs && vite build --config vite.config.chrome.js",
    "build:chrome:zip": "npm run build:chrome && cd chrome-dist && zip -r ../chrome-extension.zip ."
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "playwright": "^1.60.0",
    "three": "^0.160.0",
    "vue": "^3.5.35"
  },
  "devDependencies": {
    "gh-pages": "^6.3.0",
    "vite": "^5.4.21"
  }
}
